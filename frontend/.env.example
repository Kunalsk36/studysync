# StudySync Frontend — Environment Variable Reference
# Copy this file to frontend/.env.local and fill in real values. Never commit .env.local.
#
# Next.js only exposes variables prefixed NEXT_PUBLIC_ to the browser — both
# variables below are intentionally public (a Google OAuth Client ID is not
# a secret; the matching Client Secret stays backend-only, never here).

# Backend API base URL.
NEXT_PUBLIC_API_URL=http://localhost:5000

# Must match backend/.env's GOOGLE_CLIENT_ID — required for Google Sign-In (GIS).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
