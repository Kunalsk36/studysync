# StudySync Backend — Environment Variable Reference
# Copy this file to backend/.env and fill in real values. Never commit .env.

# ---- Server ----
# Safe to default in development; Railway/production platforms typically
# inject PORT and NODE_ENV=production automatically.
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ---- Database (MySQL) ----
# Host/port are safe to default locally. NAME/USER/PASSWORD are required in
# production (see config/index.js REQUIRED_IN_PRODUCTION) — no fallback is
# ever substituted for them outside development.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=studysync
DB_USER=root
DB_PASSWORD=

# ---- Authentication ----
# JWT_SECRET: required everywhere, never defaulted. Generate a strong value with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_EXPIRES_IN accepts a duration string ("15m", "1h", "7d"); the auth
# cookie's maxAge is derived from this same value automatically.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Google Cloud OAuth Client (required in production — see 05-API.md §6).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Email (password reset) ----
# Provider-independent — leave blank in development to auto-provision a free
# Ethereal Email test inbox (see src/utils/mailer.js). Set these to point at
# a real SMTP provider for production; optional otherwise.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---- AI Assistant ----
# Configurable provider — see 02-TechSpec.md §7.1. Optional; unused until the
# AI Assistant module is implemented.
AI_PROVIDER=
