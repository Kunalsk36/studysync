# StudySync — Environment Variable Reference
# Copy this file to .env and fill in real values. Never commit .env.

# ---- Server ----
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ---- Database (MySQL) ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=studysync
DB_USER=root
DB_PASSWORD=

# ---- Authentication ----
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Frontend (Next.js — must be prefixed NEXT_PUBLIC_ to reach the browser) ----
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ---- Email (password reset) ----
# Provider-independent — leave blank in development to auto-provision a free
# Ethereal Email test inbox (see backend/src/utils/mailer.js). Set these to
# point at a real SMTP provider for production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---- AI Assistant ----
# Configurable provider — see 02-TechSpec.md §7.1
AI_PROVIDER=
