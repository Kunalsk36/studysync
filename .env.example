# StudySync — Environment Variable Reference
# Copy this file to .env and fill in real values. Never commit .env.

# ---- Server ----
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ---- Database (MySQL) ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=studysync
DB_USER=root
DB_PASSWORD=

# ---- Authentication ----
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- AI Assistant ----
# Configurable provider — see 02-TechSpec.md §7.1
AI_PROVIDER=
